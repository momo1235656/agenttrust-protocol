# Build stage
FROM rust:1.80-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Cache dependencies
COPY server-rust/Cargo.toml ./
COPY server-rust/Cargo.loc[k] ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && cargo build --release && rm src/main.rs

# Build the actual application
COPY server-rust/src ./src
COPY server-rust/migrations ./migrations
RUN touch src/main.rs && cargo build --release

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/agenttrust-server /usr/local/bin/
COPY --from=builder /app/migrations /app/migrations

WORKDIR /app

EXPOSE 8000

CMD ["agenttrust-server"]
