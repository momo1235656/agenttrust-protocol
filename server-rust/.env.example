# AgentTrust Server v0.2.0 - Rust Edition
# Copy this file to .env and fill in the values

# Server
PORT=8000

# PostgreSQL
DATABASE_URL=postgres://agenttrust:agenttrust_dev@localhost:5432/agenttrust

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (use sk_test_* for test mode, sk_live_* for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# JWT signing key (Ed25519 private key, base64-encoded 32 bytes)
# Leave empty to auto-generate on startup
JWT_SERVER_PRIVATE_KEY=
JWT_SERVER_PUBLIC_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# DID document store path (for backward compatibility with Python server)
DID_STORE_PATH=./data/dids

# Rate limiting
RATE_LIMIT_PER_AGENT_PER_MINUTE=60
RATE_LIMIT_PER_IP_PER_MINUTE=120

# Approval
APPROVAL_WEBHOOK_DEFAULT_URL=
APPROVAL_EXPIRY_HOURS=24

# Human-in-the-Loop: amount threshold (JPY) above which approval is required
APPROVAL_REQUIRED_ABOVE=30000
